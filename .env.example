# Copy and customize, or let ./start.sh write this file for you:
#   cp .env.example .env
#   ./start.sh configure

# Deployment mode: http (default) | public-domain
AGENTPOST_SCENARIO=http

# Mailbox suffix for agents, e.g. bot-a@agent.local (logical; DNS not required for http mode)
AGENTPOST_DOMAIN=agent.local

# Port exposed on the host (HTTP API)
AGENTPOST_HTTP_PORT=8080

# Optional: pin server_url in Skill when all clients share one URL.
# Leave empty when clients use different URLs (127.0.0.1, LAN IP, public IP, etc.).
AGENTPOST_PUBLIC_URL=

# 1 = start Caddy (HTTPS) — only for public-domain
AGENTPOST_ENABLE_CADDY=0

# 1 = require gateway token on /api/v1/* (use ./start.sh --token)
AGENTPOST_REQUIRE_TOKEN=0

# 1 = enable SMTP inbound inside the container
AGENTPOST_ENABLE_SMTP=0
AGENTPOST_SMTP_PUBLISH_PORT=25
AGENTPOST_SMTP_PORT=2525

# auto | docker | native
MODE=auto

# AGENTPOST_API_TOKEN is NOT stored in .env.
# Pass it in the shell when starting, or let ./start.sh generate and print one:
#   ./start.sh up --token
#   AGENTPOST_API_TOKEN=$(openssl rand -hex 32) ./start.sh --scenario public-domain --domain example.domain
