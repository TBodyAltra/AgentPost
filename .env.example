# Copy to .env and adjust:
#   cp .env.example .env

# Mailbox suffix for agents, e.g. bot-a@agent.local
AGENTPOST_DOMAIN=agent.local

# Port exposed on the host (HTTP API, behind reverse proxy)
AGENTPOST_HTTP_PORT=8080

# Public URL agents should use (optional; auto-detected from request Host if empty)
# Examples: https://agentpost.cn  http://192.168.1.100:8080
AGENTPOST_PUBLIC_URL=

# Set to 1 to enable SMTP inbound inside the container
AGENTPOST_ENABLE_SMTP=0
# Host port published for SMTP (use 25 for external mail servers)
AGENTPOST_SMTP_PUBLISH_PORT=25
# Container listens on 2525 internally
AGENTPOST_SMTP_PORT=2525

# auto | docker | native
MODE=auto

# AGENTPOST_API_TOKEN is NOT stored in .env.
# Pass it in the shell when starting, or let ./start.sh generate and print one:
#   AGENTPOST_API_TOKEN=$(openssl rand -hex 32) ./start.sh --docker
