# Copy to .env and adjust:
#   cp .env.example .env

# Mailbox suffix for agents, e.g. bot-a@agentpost.cn
AGENTPOST_DOMAIN=agentpost.cn

# Port exposed on the host (HTTP API, behind reverse proxy)
AGENTPOST_HTTP_PORT=8080

# Gateway token for public HTTP API (Authorization: Bearer <token>)
AGENTPOST_API_TOKEN=

# Set to 1 to enable SMTP inbound inside the container
AGENTPOST_ENABLE_SMTP=0
# Host port published for SMTP (use 25 for external mail servers)
AGENTPOST_SMTP_PUBLISH_PORT=25
# Container listens on 2525 internally
AGENTPOST_SMTP_PORT=2525

# auto | docker | native
MODE=auto
