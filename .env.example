# Copy and customize, or let ./start.sh write this file for you:
#   cp .env.example .env
#   ./start.sh up

# Default deployment (./start.sh up). Legacy: local | lan | public-ip | public-domain
AGENTPOST_SCENARIO=http

# Mailbox suffix for agents, e.g. bot-a@agent.local
AGENTPOST_DOMAIN=agent.local

# Port exposed on the host (HTTP API)
AGENTPOST_HTTP_PORT=8080

# Optional single URL (legacy). Leave unset so each client uses a reachable URL from CONNECT_* below.
AGENTPOST_PUBLIC_URL=

# Client connection URLs written by ./start.sh (omitted when not available)
AGENTPOST_CONNECT_LOCALHOST=http://127.0.0.1:8080
# AGENTPOST_CONNECT_LAN=http://192.168.1.100:8080
# AGENTPOST_CONNECT_PUBLIC=http://203.0.113.10:8080
# AGENTPOST_CONNECT_DOMAIN=https://example.domain

# 1 = start Caddy (HTTPS) when using --domain with --caddy
AGENTPOST_ENABLE_CADDY=0

# 1 = require gateway token on /api/v1/*
AGENTPOST_REQUIRE_TOKEN=0

# 1 = enable SMTP inbound inside the container
AGENTPOST_ENABLE_SMTP=0
AGENTPOST_SMTP_PUBLISH_PORT=25
AGENTPOST_SMTP_PORT=2525

# auto | docker | native
MODE=auto

# AGENTPOST_API_TOKEN is NOT stored in .env.
# Pass it in the shell when starting, or let ./start.sh generate and print one:
#   AGENTPOST_API_TOKEN=$(openssl rand -hex 32) ./start.sh up --token
