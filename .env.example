# Copy and customize, or let ./start.sh write this file for you:
#   cp .env.example .env
#   ./start.sh configure

# Deployment scenario (required for predictable skill URLs):
#   local | lan | public-ip | public-domain
AGENTPOST_SCENARIO=

# Mailbox suffix for agents, e.g. bot-a@agent.local (logical; DNS not required for local/lan/public-ip)
AGENTPOST_DOMAIN=agent.local

# Port exposed on the host (HTTP API)
AGENTPOST_HTTP_PORT=8080

# Canonical URL agents MUST use — written by ./start.sh per scenario:
#   local:          http://127.0.0.1:8080
#   lan:            http://192.168.1.100:8080
#   public-ip:      http://203.0.113.10:8080
#   public-domain:  https://example.com
AGENTPOST_PUBLIC_URL=

# 1 = start Caddy (HTTPS) — only for public-domain
AGENTPOST_ENABLE_CADDY=0

# 1 = require gateway token on /api/v1/* (recommended for public-*)
AGENTPOST_REQUIRE_TOKEN=0

# 1 = enable SMTP inbound inside the container
AGENTPOST_ENABLE_SMTP=0
AGENTPOST_SMTP_PUBLISH_PORT=25
AGENTPOST_SMTP_PORT=2525

# auto | docker | native
MODE=auto

# AGENTPOST_API_TOKEN is NOT stored in .env.
# Pass it in the shell when starting, or let ./start.sh generate and print one:
#   AGENTPOST_API_TOKEN=$(openssl rand -hex 32) ./start.sh --scenario public-domain --domain example.com
