# Copy and customize, or let ./start.sh write this file for you:
#   cp .env.example .env
#   ./start.sh up

# Mailbox suffix for agents, e.g. bot-a@agent.local (logical; DNS not required for HTTP API)
AGENTPOST_DOMAIN=agent.local

# Port exposed on the host (HTTP API)
AGENTPOST_HTTP_PORT=8080

# Client connection URLs (written by ./start.sh; each agent picks one it can reach)
AGENTPOST_CONNECT_LOCALHOST=http://127.0.0.1:8080
# AGENTPOST_CONNECT_LAN=http://192.168.1.100:8080
# AGENTPOST_CONNECT_PUBLIC=http://203.0.113.10:8080
# AGENTPOST_CONNECT_DOMAIN=https://example.domain

# 1 = start Caddy (HTTPS) when using --domain --caddy
AGENTPOST_ENABLE_CADDY=0

# 1 = require gateway token on /api/v1/* (default when using ./start.sh up)
AGENTPOST_REQUIRE_TOKEN=1

# 1 = enable SMTP inbound inside the container
AGENTPOST_ENABLE_SMTP=0
AGENTPOST_SMTP_PUBLISH_PORT=25
AGENTPOST_SMTP_PORT=2525

# auto | docker | native
MODE=auto

# AGENTPOST_API_TOKEN is NOT stored in .env.
# ./start.sh saves it to .agentpost/gateway.token and reuses it on the next up.
# Override in the shell if needed:
#   AGENTPOST_API_TOKEN=$(openssl rand -hex 32) ./start.sh up

# Registered mailboxes persist here (queues and message log do not):
# AGENTPOST_DATA_DIR=.agentpost/data
