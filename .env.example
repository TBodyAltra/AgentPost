# Copy to .env and adjust:
#   cp .env.example .env

# Mailbox suffix for agents, e.g. bot-a@agent.local
AGENTPOST_DOMAIN=agent.local

# Port exposed on the host
AGENTPOST_HTTP_PORT=8080

# Set to 1 to enable SMTP inbound inside the container
AGENTPOST_ENABLE_SMTP=0
AGENTPOST_SMTP_PORT=2525

# auto | docker | native
MODE=auto
